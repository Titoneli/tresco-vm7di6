                            background: 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',\
                            borderRadius: '12px',\
                            color: 'white'\
                        \}\}>\
                            <div style=\{\{ fontSize: '14px', opacity: 0.9, marginBottom: '8px' \}\}>\uc0\u10060  Ordens Canceladas</div>\
                            <div style=\{\{ fontSize: '28px', fontWeight: 'bold' \}\}>\
                                \{formatNumber(ordensMetrics?.totalCanceladas || 0)\}\
                            </div>\
                            <div style=\{\{ fontSize: '12px', opacity: 0.8, marginTop: '4px' \}\}>Total de cancelamentos</div>\
                        </div>\
\
                        <div style=\{\{ \
                            padding: '20px', \
                            background: 'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',\
                            borderRadius: '12px',\
                            color: 'white'\
                        \}\}>\
                            <div style=\{\{ fontSize: '14px', opacity: 0.9, marginBottom: '8px' \}\}>\uc0\u9989  Taxa de Conclus\'e3o</div>\
                            <div style=\{\{ fontSize: '28px', fontWeight: 'bold' \}\}>\
                                \{ordensMetrics?.totalOrdens ? ((ordensMetrics.totalConcluidas / ordensMetrics.totalOrdens) * 100).toFixed(1) : 0\}%\
                            </div>\
                            <div style=\{\{ fontSize: '12px', opacity: 0.8, marginTop: '4px' \}\}>Percentual de ordens conclu\'eddas</div>\
                        </div>\
                    </div>\
                </main>\
            )\}\
\
            \{/* Dados Tab */\}\
            \{activeTab === 'dados' && !loading && (\
                <main className="dashboard-content">\
                    <h1 className="page-title">\
                        Dados - \{viewMode === 'duplicados' ? 'Boletos Duplicados' : viewMode === 'programacao-envios' ? 'Programa\'e7\'e3o de Envios' : viewMode === 'ordens-servico' ? 'Ordens de Servi\'e7o' : 'Ve\'edculos sem Boletos'\}\
                    </h1>\
                    \
                    \{/* Summary Cards in Data View - Only for Boletos Duplicados */\}\
                    \{viewMode === 'duplicados' && (\
                        <div className="data-summary-row">\
                            <div className="data-summary-card">\
                                <span className="data-summary-label">Total de Placas</span>\
                                <span className="data-summary-value">\{formatNumber(metrics?.totalPlacas || 0)\}</span>\
                            </div>\
                            <div className="data-summary-card">\
                                <span className="data-summary-label">Total de Boletos</span>\
                                <span className="data-summary-value">\{formatNumber(metrics?.totalBoletosDuplicados || 0)\}</span>\
                            </div>\
                            <div className="data-summary-card">\
                                <span className="data-summary-label">Valor Total</span>\
                                <span className="data-summary-value">\{formatCurrency(metrics?.valorTotal || 0)\}</span>\
                            </div>\
                            <div className="data-summary-card">\
                                <span className="data-summary-label">% Duplicados</span>\
                                <span className="data-summary-value">\{(metrics?.percentualDuplicados || 0).toFixed(2)\}%</span>\
                            </div>\
                        </div>\
                    )\}\
                    \
                    \{/* Tabela para Boletos Duplicados */\}\
                    \{viewMode === 'duplicados' && (\
                        <div className="table-container">\
                            <div className="table-header">\
                                <h2 className="table-title">\
                                    Boletos por Placa\
                                    <span className="table-count"> (\{filteredBoletos.length\} registros)</span>\
                                </h2>\
                            </div>\
                            \
                            \{filteredBoletos.length === 0 ? (\
                                <div className="no-data">\
                                    <div className="no-data-icon">\uc0\u55357 \u56523 </div>\
                                    <p>Nenhum boleto duplicado encontrado.</p>\
                                </div>\
                            ) : (\
                                <table>\
                                    <thead>\
                                        <tr>\
                                            <th>Placa</th>\
                                            <th>M\'eas Refer\'eancia</th>\
                                            <th>Qtd. Boletos</th>\
                                            <th>Status</th>\
                                        </tr>\
                                    </thead>\
                                    <tbody>\
                                        \{filteredBoletos.map((item, index) => (\
                                            <tr key=\{`$\{item.placa\}-$\{item.mes_ref\}-$\{index\}`\}>\
                                                <td>\
                                                    <a \
                                                        href=\{`https://orion.hinova.com.br/sga/sgav4_conecta/veiculo/consultarVeiculo.php?Placa=$\{item.placa\}`\}\
                                                        target="_blank"\
                                                        rel="noopener noreferrer"\
                                                        className="placa-link"\
                                                    >\
                                                        <strong>\{item.placa\}</strong>\
                                                    </a>\
                                                </td>\
                                                <td>\{item.mes_ref\}</td>\
                                                <td>\
                                                    <span className="badge-count">\{item.qtd_boletos\}</span>\
                                                </td>\
                                                <td>\
                                                    <span className=\{`badge-status $\{item.qtd_boletos > 2 ? 'pending' : 'accepted'\}`\}>\
                                                        \{item.qtd_boletos > 2 ? 'Pendente' : 'Analisado'\}\
                                                    </span>\
                                                </td>\
                                            </tr>\
                                        ))\}\
                                    </tbody>\
                                </table>\
                            )\}\
                        </div>\
                    )\}\
\
                    \{/* Tabela para Programa\'e7\'e3o de Envios */\}\
                    \{viewMode === 'programacao-envios' && (\
                        <div className="table-container">\
                            <div className="table-header">\
                                <h2 className="table-title">\
                                    \uc0\u55357 \u56517  Programa\'e7\'e3o de Envios - M\'eas Corrente\
                                    <span className="table-count"> (\{programacaoEnvios.length\} datas programadas)</span>\
                                </h2>\
                            </div>\
                            \
                            \{/* Legenda de Tipos de Envio */\}\
                            <div className="color-legend" style=\{\{ marginBottom: '16px' \}\}>\
                                <div className="legend-item">\
                                    <span style=\{\{ \
                                        display: 'inline-block',\
                                        width: '12px',\
                                        height: '12px',\
                                        borderRadius: '50%',\
                                        backgroundColor: '#667eea',\
                                        marginRight: '8px'\
                                    \}\}></span>\
                                    <span className="legend-text">\uc0\u55357 \u56596  Lembrete de Vencimento (no dia)</span>\
                                </div>\
                                <div className="legend-item">\
                                    <span style=\{\{ \
                                        display: 'inline-block',\
                                        width: '12px',\
                                        height: '12px',\
                                        borderRadius: '50%',\
                                        backgroundColor: '#f5576c',\
                                        marginRight: '8px'\
                                    \}\}></span>\
                                    <span className="legend-text">\uc0\u9888 \u65039  Alerta 2\'ba Dia \'datil (ap\'f3s vencimento)</span>\
                                </div>\
                                <div className="legend-item">\
                                    <span style=\{\{ \
                                        display: 'inline-block',\
                                        width: '12px',\
                                        height: '12px',\
                                        borderRadius: '50%',\
                                        backgroundColor: '#fee140',\
                                        marginRight: '8px'\
                                    \}\}></span>\
                                    <span className="legend-text">\uc0\u55357 \u57000  Alerta 5\'ba Dia Corrido (ap\'f3s vencimento)</span>\
                                </div>\
                            </div>\
                            \
                            \{programacaoEnvios.length === 0 ? (\
                                <div className="no-data">\
                                    <div className="no-data-icon">\uc0\u55357 \u56517 </div>\
                                    <p>Nenhuma programa\'e7\'e3o de envio encontrada para o m\'eas atual.</p>\
                                </div>\
                            ) : (\
                                <table>\
                                    <thead>\
                                        <tr>\
                                            <th>Dia Vencimento</th>\
                                            <th>Data Vencimento</th>\
                                            <th>\uc0\u55357 \u56596  Vencimento Ajustado</th>\
                                            <th>\uc0\u9888 \u65039  2\'ba Dia \'datil</th>\
                                            <th>\uc0\u55357 \u57000  5\'ba Dia Corrido</th>\
                                        </tr>\
                                    </thead>\
                                    <tbody>\
                                        \{programacaoEnvios.map((prog, index) => \{\
                                            const hoje = new Date().toISOString().split('T')[0];\
                                            const isVencimentoHoje = prog.data_vencimento_ajustada === hoje;\
                                            const is2DiasHoje = prog.data_2_dias_uteis === hoje;\
                                            const is5DiasHoje = prog.data_5_dias_corridos === hoje;\
                                            \
                                            return (\
                                                <tr key=\{`prog-$\{index\}`\}>\
                                                    <td><strong>\{prog.dia_vencimento\}</strong></td>\
                                                    <td>\{formatDateBR(prog.data_vencimento)\}</td>\
                                                    <td style=\{\{ \
                                                        backgroundColor: isVencimentoHoje ? '#667eea' : 'transparent',\
                                                        color: isVencimentoHoje ? 'white' : 'inherit',\
                                                        fontWeight: isVencimentoHoje ? 'bold' : 'normal'\
                                                    \}\}>\
                                                        \{formatDateBR(prog.data_vencimento_ajustada)\}\
                                                        \{isVencimentoHoje && ' \uc0\u55357 \u56596 '\}\
                                                    </td>\
                                                    <td style=\{\{ \
                                                        backgroundColor: is2DiasHoje ? '#f5576c' : 'transparent',\
                                                        color: is2DiasHoje ? 'white' : 'inherit',\
                                                        fontWeight: is2DiasHoje ? 'bold' : 'normal'\
                                                    \}\}>\
                                                        \{formatDateBR(prog.data_2_dias_uteis)\}\
                                                        \{is2DiasHoje && ' \uc0\u9888 \u65039 '\}\
                                                    </td>\
                                                    <td style=\{\{ \
                                                        backgroundColor: is5DiasHoje ? '#fee140' : 'transparent',\
                                                        color: is5DiasHoje ? '#333' : 'inherit',\
                                                        fontWeight: is5DiasHoje ? 'bold' : 'normal'\
                                                    \}\}>\
                                                        \{formatDateBR(prog.data_5_dias_corridos)\}\
                                                        \{is5DiasHoje && ' \uc0\u55357 \u57000 '\}\
                                                    </td>\
                                                </tr>\
                                            );\
                                        \})\}\
                                    </tbody>\
                                </table>\
                            )\}\
                        </div>\
                    )\}\
                    \
                    \{/* Tabela para Ve\'edculos sem Boletos */\}\
                    \{viewMode === 'sem-boletos' && (\
                        <div className="table-container">\
                            <div className="table-header">\
                                <h2 className="table-title">\
                                    Ve\'edculos sem Boletos de Fechamento\
                                    <span className="table-count"> (\{filteredVeiculos.length\} registros)</span>\
                                </h2>\
                            </div>\
                            \
                            \{/* Legenda de Cores */\}\
                            <div className="color-legend">\
                                <div className="legend-item">\
                                    <span className="legend-badge never"></span>\
                                    <span className="legend-text">Nunca teve fechamento</span>\
                                </div>\
                                <div className="legend-item">\
                                    <span className="legend-badge critical"></span>\
                                    <span className="legend-text">Mais de 60 dias sem boletos</span>\
                                </div>\
                                <div className="legend-item">\
                                    <span className="legend-badge warning"></span>\
                                    <span className="legend-text">De 31 a 60 dias sem fechamento</span>\
                                </div>\
                                <div className="legend-item">\
                                    <span className="legend-badge success"></span>\
                                    <span className="legend-text">At\'e9 30 dias sem fechamento</span>\
                                </div>\
                            </div>\
                            \
                            \{filteredVeiculos.length === 0 ? (\
                                <div className="no-data">\
                                    <div className="no-data-icon">\uc0\u9989 </div>\
                                    <p>Nenhum ve\'edculo encontrado com os filtros aplicados.</p>\
                                </div>\
                            ) : (\
                                <table>\
                                    <thead>\
                                        <tr>\
                                            <th>Ranking</th>\
                                            <th>Placa</th>\
                                            <th>Data Contrato</th>\
                                            <th>M\'eas Referente</th>\
                                            <th>Primeiro Fechamento</th>\
                                            <th>\'daltimo Fechamento</th>\
                                            <th>Dias desde Primeiro</th>\
                                            <th>Dias desde \'daltimo</th>\
                                            <th>Status</th>\
                                        </tr>\
                                    </thead>\
                                    <tbody>\
                                        \{filteredVeiculos.map((item, index) => (\
                                            <tr key=\{`$\{item.placa\}-$\{index\}`\}>\
                                                <td>\
                                                    <span className="badge-count">\
                                                        #\{item.ranking_maior_tempo_sem_fechamento\}\
                                                    </span>\
                                                </td>\
                                                <td>\
                                                    <a \
                                                        href=\{`https://orion.hinova.com.br/sga/sgav4_conecta/veiculo/consultarVeiculo.php?Placa=$\{item.placa\}`\}\
                                                        target="_blank"\
                                                        rel="noopener noreferrer"\
                                                        className="placa-link"\
                                                    >\
                                                        <strong>\{item.placa\}</strong>\
                                                    </a>\
                                                </td>\
                                                <td>\{item.data_contrato || '-'\}</td>\
                                                <td>\{item.mes_referente || '-'\}</td>\
                                                <td>\{item.primeiro_boleto || '-'\}</td>\
                                                <td>\{item.ultimo_boleto || 'Nunca'\}</td>\
                                                <td>\
                                                    \{item.dias_desde_primeiro_fechamento ? \
                                                        `$\{formatNumber(item.dias_desde_primeiro_fechamento)\} dias` : '-'\}\
                                                </td>\
                                                <td>\
                                                    <span className=\{`badge-count $\{\
                                                        item.nunca_teve_fechamento ? 'never' :\
                                                        (item.dias_desde_ultimo_fechamento || 0) > 60 ? 'critical' :\
                                                        (item.dias_desde_ultimo_fechamento || 0) > 30 ? 'warning' : 'success'\
                                                    \}`\}>\
                                                        \{item.dias_desde_ultimo_fechamento ? \
                                                            `$\{formatNumber(item.dias_desde_ultimo_fechamento)\} dias` : '-'\}\
                                                    </span>\
                                                </td>\
                                                <td>\
                                                    <span className=\{`badge-status $\{\
                                                        item.nunca_teve_fechamento ? 'rejected' :\
                                                        item.teve_fechamento_ano_atual ? 'accepted' : 'pending'\
                                                    \}`\}>\
                                                        \{item.nunca_teve_fechamento ? 'Nunca Teve' :\
                                                         item.teve_fechamento_ano_atual ? 'Ano Atual' : 'Sem Ano Atual'\}\
                                                    </span>\
                                                </td>\
                                            </tr>\
                                        ))\}\
                                    </tbody>\
                                </table>\
                            )\}\
                        </div>\
                    )\}\
\
                    \{/* Tabela para Ordens de Servi\'e7o */\}\
                    \{viewMode === 'ordens-servico' && (\
                        <div className="table-container">\
                            <div className="table-header">\
                                <h2 className="table-title">\
                                    \uc0\u55357 \u56615  Ordens de Servi\'e7o\
                                    <span className="table-count"> (\{ordensServico.length\} registros)</span>\
                                </h2>\
                            </div>\
                            \
                            \{/* Legenda de Status */\}\
                            <div className="color-legend" style=\{\{ marginBottom: '16px' \}\}>\
                                <div className="legend-item">\
                                    <span style=\{\{ \
                                        display: 'inline-block',\
                                        width: '12px',\
                                        height: '12px',\
                                        borderRadius: '50%',\
                                        backgroundColor: '#10B981',\
                                        marginRight: '8px'\
                                    \}\}></span>\
                                    <span className="legend-text">\uc0\u9989  Conclu\'edda</span>\
                                </div>\
                                <div className="legend-item">\
                                    <span style=\{\{ \
                                        display: 'inline-block',\
                                        width: '12px',\
                                        height: '12px',\
                                        borderRadius: '50%',\
                                        backgroundColor: '#F59E0B',\
                                        marginRight: '8px'\
                                    \}\}></span>\
                                    <span className="legend-text">\uc0\u55357 \u56580  Aberta</span>\
                                </div>\
                                <div className="legend-item">\
                                    <span style=\{\{ \
                                        display: 'inline-block',\
                                        width: '12px',\
                                        height: '12px',\
                                        borderRadius: '50%',\
                                        backgroundColor: '#EF4444',\
                                        marginRight: '8px'\
                                    \}\}></span>\
                                    <span className="legend-text">\uc0\u10060  Cancelada</span>\
                                </div>\
                            </div>\
                            \
                            \{/* Summary Cards */\}\
                            <div className="data-summary-row" style=\{\{ marginBottom: '16px' \}\}>\
                                <div className="data-summary-card">\
                                    <span className="data-summary-label">Total de Ordens</span>\
                                    <span className="data-summary-value">\{formatNumber(ordensMetrics?.totalOrdens || 0)\}</span>\
                                </div>\
                                <div className="data-summary-card">\
                                    <span className="data-summary-label">Abertas</span>\
                                    <span className="data-summary-value">\{formatNumber(ordensMetrics?.totalAbertas || 0)\}</span>\
                                </div>\
                                <div className="data-summary-card">\
                                    <span className="data-summary-label">Conclu\'eddas</span>\
                                    <span className="data-summary-value">\{formatNumber(ordensMetrics?.totalConcluidas || 0)\}</span>\
                                </div>\
                                <div className="data-summary-card">\
                                    <span className="data-summary-label">Valor Total</span>\
                                    <span className="data-summary-value">\{formatCurrency(ordensMetrics?.valorTotal || 0)\}</span>\
                                </div>\
                            </div>\
                            \
                            \{ordensServico.length === 0 ? (\
                                <div className="no-data">\
                                    <div className="no-data-icon">\uc0\u55357 \u56615 </div>\
                                    <p>Nenhuma ordem de servi\'e7o encontrada no per\'edodo.</p>\
                                </div>\
                            ) : (\
                                <table>\
                                    <thead>\
                                        <tr>\
                                            <th>Placa</th>\
                                            <th>M\'eas Refer\'eancia</th>\
                                            <th>Qtd. Ordens</th>\
                                            <th>Status</th>\
                                        </tr>\
                                    </thead>\
                                    <tbody>\
                                        \{ordensServico\
                                            .filter(item => !searchTerm || item.placa.toLowerCase().includes(searchTerm.toLowerCase()))\
                                            .map((item, index) => (\
                                            <tr key=\{`$\{item.placa\}-$\{item.mes_ref\}-$\{item.status\}-$\{index\}`\}>\
                                                <td>\
                                                    <a \
                                                        href=\{`https://orion.hinova.com.br/sga/sgav4_conecta/veiculo/consultarVeiculo.php?Placa=$\{item.placa\}`\}\
                                                        target="_blank"\
                                                        rel="noopener noreferrer"\
                                                        className="placa-link"\
                                                    >\
                                                        <strong>\{item.placa\}</strong>\
                                                    </a>\
                                                </td>\
                                                <td>\{item.mes_ref\}</td>\
                                                <td>\
                                                    <span className="badge-count">\{item.qtd_ordens\}</span>\
                                                </td>\
                                                <td>\
                                                    <span className=\{`badge-status $\{\
                                                        item.status === 'CONCLUIDA' ? 'accepted' :\
                                                        item.status === 'CANCELADA' ? 'rejected' : 'pending'\
                                                    \}`\}>\
                                                        \{item.status === 'CONCLUIDA' ? '\uc0\u9989  Conclu\'edda' :\
                                                         item.status === 'CANCELADA' ? '\uc0\u10060  Cancelada' :\
                                                         item.status === 'ABERTA' ? '\uc0\u55357 \u56580  Aberta' : item.status\}\
                                                    </span>\
                                                </td>\
                                            </tr>\
                                        ))\}\
                                    </tbody>\
                                </table>\
                            )\}\
                        </div>\
                    )\}\
                </main>\
            )\}\
        </div>\
    );\
\};\
\
export default Dashboard;\
}