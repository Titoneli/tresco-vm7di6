// Fun\'e7\'e3o para formatar data sem problema de timezone\
// Quando a string vem como "2026-01-10", o JS interpreta como UTC meia-noite\
// e ao converter para local time (UTC-3) volta um dia. Esta fun\'e7\'e3o evita isso.\
const formatDateBR = (dateString: string): string => \{\
    if (!dateString) return '-';\
    // Extrai apenas YYYY-MM-DD e formata diretamente\
    const parts = dateString.split('T')[0].split('-');\
    if (parts.length !== 3) return dateString;\
    return `$\{parts[2]\}/$\{parts[1]\}/$\{parts[0]\}`;\
\};\
